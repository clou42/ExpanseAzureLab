# Copy to .env and fill in from your `terraform apply` output.
# verify_chain.py reads these (or environment variables of the same names).

# Required: lab entrypoints from the terraform output
WEBAPP_FQDN=tycho-terminal-XXXXXXXXXXXXXXXX.azurewebsites.net
SQL_FQDN=tycho-XXXXX.database.windows.net

# Optional: enables the fast "fire trigger now" path (~10s end-to-end).
# Without these, the script falls back to waiting for a natural Donnager
# heartbeat (~5-7 min).
TENANT_ID=
ADMIN_SP_CLIENT_ID=
ADMIN_SP_SECRET=
